---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    q: 'What file formats can I upload?',
    a: 'MP4, MOV, WebM, and most common containers. We also accept direct links from YouTube and Vimeo.',
  },
  {
    q: 'How long does processing take?',
    a: 'Most videos finish in under five minutes. Very long uploads (multi-hour) can take a little longer; you’ll get an email when clips are ready.',
  },
  {
    q: 'Can I edit a clip after it’s generated?',
    a: 'Yes. Trim the in/out points, fix any caption wording, restyle captions, and re-export — no need to reprocess the source video.',
  },
  {
    q: 'Is my content private?',
    a: 'Your uploads and clips are private to your account. We don’t use your videos to train models, and you can delete them at any time.',
  },
  {
    q: 'Is there anything to cancel?',
    a: 'No — Videotrim is pay-as-you-go, so there’s no subscription to cancel. You only ever pay when you buy a token pack, and any tokens you’ve bought stay in your account until you use them.',
  },
];
---

<Layout
  title="Support — Videotrim"
  description="Get help with Videotrim. Guides, FAQs, and a real support team ready to help you ship clips."
>
  <section class="mx-auto max-w-6xl px-5 pt-16 pb-10 text-center md:pt-24">
    <span class="eyebrow">Support</span>
    <h1 class="text-balance mt-3 font-display text-5xl md:text-6xl">We're here to help you ship</h1>
    <p class="mx-auto mt-5 max-w-xl text-lg text-muted-foreground">
      Find an answer fast, or reach a human who actually uses the product.
    </p>
  </section>

  <!-- FAQ -->
  <section id="faq" class="mx-auto max-w-3xl px-5 pt-4 pb-8">
    <h2 class="text-center font-display text-3xl md:text-4xl">Frequently asked</h2>
    <div class="mt-10 space-y-3">
      {faqs.map((faq) => (
        <details class="group rounded-[var(--radius-card)] border border-card-border-subtle bg-card p-5">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-medium">
            {faq.q}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="h-4 w-4 shrink-0 text-muted-foreground transition-transform group-open:rotate-180"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="mx-auto max-w-3xl px-5 py-16">
    <div class="rounded-[var(--radius-card)] border border-card-border-subtle bg-card p-7 md:p-10">
      <h2 class="font-display text-3xl">Still stuck? Send us a note.</h2>
      <p class="mt-2 text-sm text-muted-foreground">
        Tell us what's happening and we'll get back to you by email.
      </p>
      <form class="mt-7 grid gap-4" method="post" action="#">
        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="text-sm font-medium">Name</span>
            <input type="text" name="name" required class="mt-1.5 w-full rounded-md border border-input bg-background px-3 py-2 text-sm outline-none focus:border-primary" placeholder="Your name" />
          </label>
          <label class="block">
            <span class="text-sm font-medium">Email</span>
            <input type="email" name="email" required class="mt-1.5 w-full rounded-md border border-input bg-background px-3 py-2 text-sm outline-none focus:border-primary" placeholder="you@example.com" />
          </label>
        </div>
        <label class="block">
          <span class="text-sm font-medium">How can we help?</span>
          <textarea name="message" rows="5" required class="mt-1.5 w-full resize-y rounded-md border border-input bg-background px-3 py-2 text-sm outline-none focus:border-primary" placeholder="Describe the issue or question…"></textarea>
        </label>
        <div class="flex items-center justify-between gap-4">
          <p class="text-xs text-muted-foreground">We typically reply within a few hours.</p>
          <button type="submit" class="btn btn-primary">Send message</button>
        </div>
      </form>
    </div>
  </section>
</Layout>
