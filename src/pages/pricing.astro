---
import Layout from '../layouts/Layout.astro';

const tiers = [
  {
    name: 'Free',
    price: '$0',
    period: 'forever',
    blurb: 'Try it on your next upload.',
    cta: 'Start free',
    href: '/signup',
    featured: false,
    features: [
      '3 videos per month',
      'Up to 30 min per video',
      'Auto clip detection',
      'Auto captions',
      '720p exports with watermark',
    ],
  },
  {
    name: 'Creator',
    price: '$19',
    period: 'per month',
    blurb: 'For the steady one-a-week creator.',
    cta: 'Start Creator',
    href: '/signup?plan=creator',
    featured: true,
    features: [
      '30 videos per month',
      'Up to 2 hr per video',
      'No watermark, 1080p exports',
      'Vertical / square / wide reframing',
      'Custom caption presets',
      'Batch export',
    ],
  },
  {
    name: 'Studio',
    price: '$49',
    period: 'per month',
    blurb: 'For teams shipping daily.',
    cta: 'Start Studio',
    href: '/signup?plan=studio',
    featured: false,
    features: [
      'Unlimited videos',
      'Up to 4 hr per video',
      '4K exports',
      '3 team seats included',
      'Brand kits & shared presets',
      'Priority rendering & support',
    ],
  },
];

const compare = [
  { label: 'Monthly videos', free: '3', creator: '30', studio: 'Unlimited' },
  { label: 'Max length', free: '30 min', creator: '2 hr', studio: '4 hr' },
  { label: 'Export quality', free: '720p', creator: '1080p', studio: '4K' },
  { label: 'Watermark', free: 'Yes', creator: 'No', studio: 'No' },
  { label: 'Vertical reframing', free: '—', creator: 'Yes', studio: 'Yes' },
  { label: 'Caption presets', free: '1', creator: 'Unlimited', studio: 'Unlimited' },
  { label: 'Team seats', free: '1', creator: '1', studio: '3' },
  { label: 'Priority support', free: '—', creator: '—', studio: 'Yes' },
];

const faqs = [
  {
    q: 'What counts as a “video”?',
    a: 'One source upload you process. The clips it produces don’t count against your quota — trim a 60-minute podcast into 15 shorts and that’s still one video.',
  },
  {
    q: 'Can I change plans later?',
    a: 'Anytime. Upgrades apply immediately and we prorate the difference. Downgrades take effect at your next billing date.',
  },
  {
    q: 'Do you offer annual billing?',
    a: 'Yes — pay yearly and get two months free on Creator and Studio. You can switch from monthly in your account settings.',
  },
  {
    q: 'Is there a free trial of paid features?',
    a: 'The Free plan lets you try detection and captions on every upload. Paid plans add reframing, presets, and watermark-free HD exports.',
  },
];
---

<Layout
  title="Pricing — Videotrim"
  description="Simple plans for every creator. Start free, upgrade when you're ready. No credit card required."
>
  <section class="mx-auto max-w-6xl px-5 pt-16 pb-10 text-center md:pt-24">
    <span class="eyebrow">Pricing</span>
    <h1 class="text-balance mt-3 font-display text-5xl md:text-6xl">Simple plans that scale with your output</h1>
    <p class="mx-auto mt-5 max-w-xl text-lg text-muted-foreground">
      Start free. Upgrade when clips become a habit. Every plan includes
      automatic detection and captions.
    </p>
  </section>

  <!-- Tiers -->
  <section class="mx-auto max-w-6xl px-5">
    <div class="grid gap-6 lg:grid-cols-3">
      {tiers.map((tier) => (
        <div
          class:list={[
            'relative flex flex-col rounded-[var(--radius-card)] border bg-card p-7',
            tier.featured ? 'border-primary ring-1 ring-primary' : 'border-card-border-subtle',
          ]}
        >
          {tier.featured && (
            <span class="absolute -top-3 left-7 rounded-full bg-primary px-3 py-1 text-xs font-semibold text-primary-foreground">
              Most popular
            </span>
          )}
          <h2 class="text-xl">{tier.name}</h2>
          <p class="mt-1 text-sm text-muted-foreground">{tier.blurb}</p>
          <div class="mt-5 flex items-baseline gap-1.5">
            <span class="font-display text-5xl">{tier.price}</span>
            <span class="text-sm text-muted-foreground">/ {tier.period}</span>
          </div>
          <a
            href={tier.href}
            class:list={['btn mt-6 w-full', tier.featured ? 'btn-primary' : 'btn-outline']}
          >
            {tier.cta}
          </a>
          <ul class="mt-7 space-y-3">
            {tier.features.map((f) => (
              <li class="flex items-start gap-2.5 text-sm">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 shrink-0 text-primary"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-foreground/90">{f}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <p class="mt-6 text-center text-sm text-muted-foreground">
      Need more seats or volume? <a href="/support#contact" class="font-medium text-primary hover:underline">Talk to us about Enterprise.</a>
    </p>
  </section>

  <!-- Comparison table -->
  <section class="mx-auto max-w-5xl px-5 py-20">
    <h2 class="text-center font-display text-3xl md:text-4xl">Compare every plan</h2>
    <div class="mt-10 overflow-x-auto rounded-[var(--radius-card)] border border-card-border-subtle">
      <table class="w-full min-w-[640px] border-collapse text-sm">
        <thead>
          <tr class="bg-secondary/50 text-left">
            <th class="px-5 py-4 font-medium text-muted-foreground">Feature</th>
            <th class="px-5 py-4 font-semibold">Free</th>
            <th class="px-5 py-4 font-semibold text-primary">Creator</th>
            <th class="px-5 py-4 font-semibold">Studio</th>
          </tr>
        </thead>
        <tbody>
          {compare.map((row, i) => (
            <tr class:list={['border-t border-border/70', i % 2 ? 'bg-card' : 'bg-card/40']}>
              <td class="px-5 py-3.5 text-muted-foreground">{row.label}</td>
              <td class="px-5 py-3.5 text-foreground/90">{row.free}</td>
              <td class="px-5 py-3.5 text-foreground/90">{row.creator}</td>
              <td class="px-5 py-3.5 text-foreground/90">{row.studio}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-5 pb-20">
    <h2 class="text-center font-display text-3xl md:text-4xl">Pricing questions</h2>
    <div class="mt-10 space-y-3">
      {faqs.map((faq) => (
        <details class="group rounded-[var(--radius-card)] border border-card-border-subtle bg-card p-5">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-medium">
            {faq.q}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="h-4 w-4 shrink-0 text-muted-foreground transition-transform group-open:rotate-180"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-5 pb-24">
    <div class="rounded-[var(--radius-card)] border border-card-border-subtle bg-card px-6 py-14 text-center">
      <h2 class="font-display text-3xl md:text-4xl">Still deciding? Start on Free.</h2>
      <p class="mx-auto mt-3 max-w-md text-muted-foreground">You can upgrade the moment you fall in love with the clips.</p>
      <a href="/signup" class="btn btn-primary btn-lg mt-7">Create free account</a>
    </div>
  </section>
</Layout>
