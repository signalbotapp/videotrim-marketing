---
import Layout from '../layouts/Layout.astro';

const packs = [
  {
    name: 'Free',
    price: '€0',
    tokens: 'forever',
    perToken: '2 free tokens',
    videos: '1 video',
    blurb: 'Free to sign up — try it on your next upload.',
    cta: 'Start free',
    href: '/signup',
    featured: false,
    save: null,
  },
  {
    name: 'Starter',
    price: '€5',
    tokens: '10 tokens',
    perToken: '€0.50 / token',
    videos: '5 videos',
    blurb: 'Dip your toes in.',
    cta: 'Buy 10 tokens',
    href: '/signup?pack=starter',
    featured: false,
    save: null,
  },
  {
    name: 'Creator',
    price: '€20',
    tokens: '50 tokens',
    perToken: '€0.40 / token',
    videos: '25 videos',
    blurb: 'For the steady one-a-week creator.',
    cta: 'Buy 50 tokens',
    href: '/signup?pack=creator',
    featured: true,
    save: 'Save 20%',
  },
];

// Everything is unlocked on every account — you only spend tokens per video.
const included = [
  'Auto clip detection',
  'Word-perfect auto captions',
  'Vertical / wide reframing',
  'Multiple caption presets',
  'No watermark · Full HD exports',
];

---

<Layout
  title="Pricing — Videotrim"
  description="Pay as you go with tokens — no subscription. €5 for 10 tokens, 2 tokens per video. Sign up free and get 2 tokens."
>
  <section class="mx-auto max-w-6xl px-5 pt-16 pb-10 text-center md:pt-24">
    <span class="eyebrow">Pricing</span>
    <h1 class="text-balance mt-3 font-display text-5xl md:text-6xl">Pay only for the videos you make</h1>
    <p class="mx-auto mt-5 max-w-xl text-lg text-muted-foreground">
      No subscription. Buy a pack of tokens and spend them whenever you upload —
      2 tokens per video, and they never expire.
    </p>
  </section>

  <!-- Token packs -->
  <section class="mx-auto max-w-6xl px-5">
    <div class="grid gap-6 lg:grid-cols-3">
      {packs.map((pack) => (
        <div
          class:list={[
            'relative flex flex-col rounded-[var(--radius-card)] border bg-card p-7',
            pack.featured ? 'border-primary ring-1 ring-primary' : 'border-card-border-subtle',
          ]}
        >
          {pack.featured && (
            <span class="absolute -top-3 left-7 rounded-full bg-primary px-3 py-1 text-xs font-semibold text-primary-foreground">
              Most popular
            </span>
          )}
          <div class="flex items-center justify-between">
            <h2 class="text-xl">{pack.name}</h2>
            {pack.save && (
              <span class="rounded-full bg-primary/10 px-2.5 py-1 text-xs font-semibold text-primary">{pack.save}</span>
            )}
          </div>
          <p class="mt-1 text-sm text-muted-foreground">{pack.blurb}</p>
          <div class="mt-5 flex items-baseline gap-1.5">
            <span class="font-display text-5xl">{pack.price}</span>
            <span class="text-sm text-muted-foreground">/ {pack.tokens}</span>
          </div>
          <p class="mt-1.5 text-sm text-muted-foreground">{pack.perToken} · ≈ {pack.videos}</p>
          <a
            href={pack.href}
            class:list={['btn mt-6 w-full', pack.featured ? 'btn-primary' : 'btn-outline']}
          >
            {pack.cta}
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- How tokens work -->
  <section class="mx-auto max-w-5xl px-5 py-20">
    <h2 class="text-center font-display text-3xl md:text-4xl">How tokens work</h2>
    <div class="mt-10 grid gap-4 sm:grid-cols-3">
      {[
        { stat: '2 tokens', label: 'per video', note: 'One source upload — the clips it makes are free.' },
        { stat: 'No expiry', label: 'use anytime', note: 'Tokens sit in your account until you spend them.' },
        { stat: 'No subscription', label: 'pay as you go', note: 'Top up when you need more. Cancel nothing.' },
      ].map((item) => (
        <div class="rounded-[var(--radius-card)] border border-card-border-subtle bg-card p-6 text-center">
          <p class="font-display text-3xl text-primary">{item.stat}</p>
          <p class="mt-1 text-sm font-medium">{item.label}</p>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{item.note}</p>
        </div>
      ))}
    </div>

    <div class="mt-8 rounded-[var(--radius-card)] border border-card-border-subtle bg-card p-7">
      <h3 class="text-lg font-semibold">Included with every account</h3>
      <p class="mt-1 text-sm text-muted-foreground">No feature gates — every token unlocks the full toolset.</p>
      <ul class="mt-5 grid gap-3 sm:grid-cols-2">
        {included.map((f) => (
          <li class="flex items-start gap-2.5 text-sm">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 shrink-0 text-primary"><path d="M20 6L9 17l-5-5"/></svg>
            <span class="text-foreground/90">{f}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-5 pb-24">
    <div class="rounded-[var(--radius-card)] border border-card-border-subtle bg-card px-6 py-14 text-center">
      <h2 class="font-display text-3xl md:text-4xl">Still deciding? Sign up free.</h2>
      <p class="mx-auto mt-3 max-w-md text-muted-foreground">Get 2 free tokens — a full video on us. Buy a pack only once you’re hooked.</p>
      <a href="https://app.videotrim.ai/signup" class="btn btn-primary btn-lg mt-7">Create free account</a>
    </div>
  </section>
</Layout>
