---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

const [featured, ...rest] = posts;
---

<Layout
  title="Blog — Videotrim"
  description="Workflows, insights, and playbooks for turning long videos into short-form content that performs."
>
  <section class="mx-auto max-w-6xl px-5 pt-16 pb-10 md:pt-24">
    <span class="eyebrow">The Videotrim blog</span>
    <h1 class="text-balance mt-3 max-w-2xl font-display text-5xl md:text-6xl">Playbooks for the short-form creator</h1>
    <p class="mt-5 max-w-xl text-lg text-muted-foreground">
      Workflows, data, and hard-won lessons on turning long recordings into clips
      that actually get watched.
    </p>
  </section>

  {featured && (
    <section class="mx-auto max-w-6xl px-5">
      <a href={`/blog/${featured.id}/`} class="card-hover group block overflow-hidden rounded-[var(--radius-card)] border border-card-border-subtle bg-card">
        <div class="grid md:grid-cols-2">
          <div class="relative min-h-56 bg-gradient-to-br from-[hsl(30_18%_16%)] via-[hsl(5_40%_22%)] to-[hsl(5_60%_30%)]">
            <span class="absolute left-5 top-5 rounded-full bg-background/90 px-3 py-1 text-xs font-semibold text-primary">
              Featured
            </span>
          </div>
          <div class="p-7 md:p-9">
            <div class="flex items-center gap-2 text-xs text-muted-foreground">
              <span class="font-medium text-primary">{featured.data.category}</span>
              <span>·</span>
              <span>{fmt(featured.data.pubDate)}</span>
              <span>·</span>
              <span>{featured.data.readingTime}</span>
            </div>
            <h2 class="mt-3 font-display text-2xl leading-snug md:text-3xl">{featured.data.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{featured.data.description}</p>
            <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-primary">
              Read article
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </div>
        </div>
      </a>
    </section>
  )}

  <section class="mx-auto max-w-6xl px-5 py-14">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {rest.map((post) => (
        <a href={`/blog/${post.id}/`} class="card-hover group flex flex-col overflow-hidden rounded-[var(--radius-card)] border border-card-border-subtle bg-card">
          <div class="relative h-40 bg-gradient-to-br from-[hsl(30_18%_18%)] to-[hsl(5_45%_26%)]">
            <span class="absolute left-4 top-4 rounded-full bg-background/90 px-2.5 py-1 text-xs font-semibold text-primary">
              {post.data.category}
            </span>
          </div>
          <div class="flex flex-1 flex-col p-5">
            <div class="flex items-center gap-2 text-xs text-muted-foreground">
              <span>{fmt(post.data.pubDate)}</span>
              <span>·</span>
              <span>{post.data.readingTime}</span>
            </div>
            <h3 class="mt-2 font-display text-xl leading-snug">{post.data.title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-muted-foreground">{post.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
