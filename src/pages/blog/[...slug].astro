---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

const all = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const more = all.filter((p) => p.id !== post.id).slice(0, 2);
---

<Layout title={`${post.data.title} — Videotrim`} description={post.data.description}>
  <article class="mx-auto max-w-2xl px-5 pt-14 md:pt-20">
    <a href="/blog" class="inline-flex items-center gap-1.5 text-sm font-medium text-muted-foreground hover:text-foreground">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><path d="M19 12H5M11 18l-6-6 6-6"/></svg>
      All articles
    </a>

    <div class="mt-6 flex items-center gap-2 text-xs text-muted-foreground">
      <span class="font-medium text-primary">{post.data.category}</span>
      <span>·</span>
      <span>{fmt(post.data.pubDate)}</span>
      <span>·</span>
      <span>{post.data.readingTime}</span>
    </div>

    <h1 class="text-balance mt-3 font-display text-4xl leading-[1.1] md:text-5xl">{post.data.title}</h1>
    <p class="mt-4 text-lg leading-relaxed text-muted-foreground">{post.data.description}</p>

    <div class="mt-6 flex items-center gap-3">
      <span class="grid h-9 w-9 place-items-center rounded-full bg-primary/10 text-sm font-semibold text-primary">
        {post.data.author.split(' ').map((w) => w[0]).join('').slice(0, 2)}
      </span>
      <span class="text-sm font-medium">{post.data.author}</span>
    </div>

    <hr class="divider my-10" />

    <div class="post-body">
      <Content />
    </div>

    <hr class="divider my-12" />

    <div class="rounded-[var(--radius-card)] border border-card-border-subtle bg-card p-7 text-center">
      <h2 class="font-display text-2xl">Try it on your next recording</h2>
      <p class="mx-auto mt-2 max-w-sm text-sm text-muted-foreground">
        4 free tokens to start. Upload something long and see the clips for yourself.
      </p>
      <a href="/signup" class="btn btn-primary mt-5">Start free</a>
    </div>
  </article>

  {more.length > 0 && (
    <section class="mx-auto max-w-2xl px-5 py-16">
      <h2 class="font-display text-2xl">Keep reading</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {more.map((p) => (
          <a href={`/blog/${p.id}/`} class="card-hover rounded-[var(--radius-card)] border border-card-border-subtle bg-card p-5">
            <span class="text-xs font-medium text-primary">{p.data.category}</span>
            <h3 class="mt-1.5 font-display text-lg leading-snug">{p.data.title}</h3>
            <p class="mt-1.5 text-sm text-muted-foreground line-clamp-2">{p.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}
</Layout>

<style is:global>
  .post-body {
    font-family: var(--font-serif);
    font-size: 1.075rem;
    line-height: 1.75;
    color: hsl(var(--foreground) / 0.9);
  }
  .post-body > * + * { margin-top: 1.25rem; }
  .post-body h2 {
    font-family: var(--font-display);
    font-size: 1.6rem;
    line-height: 1.3;
    margin-top: 2.5rem;
    margin-bottom: 0.25rem;
  }
  .post-body h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin-top: 2rem;
  }
  .post-body ul { padding-left: 1.25rem; list-style: disc; }
  .post-body li + li { margin-top: 0.5rem; }
  .post-body a { color: hsl(var(--primary)); text-decoration: underline; text-underline-offset: 2px; }
  .post-body strong { font-weight: 600; color: hsl(var(--foreground)); }
  .post-body blockquote {
    border-left: 3px solid hsl(var(--primary));
    padding-left: 1.25rem;
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-style: italic;
    color: hsl(var(--foreground));
  }
</style>
