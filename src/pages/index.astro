---

<Layout>
  <!-- Icons by Dwi ridwanto from Noun Project (https://thenounproject.com/browse/collection-icon/artificial-intelligence-line-24px-295290/) — CC BY 3.0 -->
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute -top-32 left-1/2 h-80 w-[42rem] -translate-x-1/2 rounded-full bg-primary/10 blur-3xl"></div>
    <div class="mx-auto grid max-w-6xl items-center gap-12 px-5 pt-16 pb-12 md:pt-24 lg:grid-cols-[2fr_1fr] lg:gap-8">
      <!-- Left: copy -->
      <div class="fade-in-up text-center lg:text-left">
        <h1 class="text-balance font-display text-5xl leading-[1.05] md:text-6xl xl:text-7xl">
          Turn one long video into <span class="text-primary">short clips</span>
        </h1>
        <p class="text-balance mx-auto mt-6 max-w-xl text-lg leading-relaxed text-muted-foreground lg:mx-0">
          Auto-captioned and ready to post. No editor to learn, no subscription
          to cancel. Pay only for what you clip.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row lg:justify-start">
          <a href="/signup" class="btn btn-primary btn-lg">
            Start free — no card needed
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="/pricing" class="btn btn-outline btn-lg">See pricing</a>
        </div>
        <p class="mt-4 text-xs text-muted-foreground">Try it for free · No subscription required · Pay as you go</p>
      </div>

      <!-- Right: 3D phone -->
      <div class="fade-in-up flex justify-center lg:justify-end">
        <PhoneMockup />
      </div>
    </div>
  </section>

  <!-- Use cases — floating, staggered photo stack -->
  <section class="overflow-x-clip py-40 md:py-52">
    <div class="mx-auto max-w-2xl px-5 text-center">
      <span class="eyebrow">Use cases</span>
      <h2 class="text-balance mt-3 font-display text-4xl md:text-5xl">Made for anyone who records more than they post</h2>
      <p class="mt-4 text-muted-foreground">If it's long and worth watching, there are clips inside it.</p>
    </div>

    <div class="no-scrollbar relative mx-auto mt-20 flex max-w-7xl snap-x snap-mandatory items-center gap-6 overflow-x-auto px-5 py-12 lg:justify-center lg:gap-8 lg:overflow-visible">
      {useCases.map((uc) => (
        <article
          class="float-card group relative aspect-square w-[min(72vw,17rem)] shrink-0 snap-center overflow-hidden rounded-[var(--radius-card)] border border-card-border-subtle"
          style={`--shift:${uc.shift};--rot:${uc.rot};`}
        >
          <img
            src={uc.img}
            alt={uc.title}
            loading="lazy"
            class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.06]"
          />
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/80 via-black/25 to-transparent"></div>
          <div class="pointer-events-none absolute inset-0 bg-black/0 transition-colors duration-500 group-hover:bg-black/45"></div>
          <div class="absolute inset-x-0 bottom-0 p-6 text-white sm:p-7">
            <p class="text-xs font-semibold uppercase tracking-wide text-white/70">{uc.audience}</p>
            <h3 class="mt-1 font-display text-2xl leading-snug text-white">{uc.title}</h3>
            <p class="reveal-text max-h-0 overflow-hidden text-sm leading-relaxed text-white/85 opacity-0 group-hover:mt-2.5 group-hover:max-h-40 group-hover:opacity-100">{uc.body}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Features -->
  <section class="dark bg-background text-foreground py-40 md:py-52">
    <div class="mx-auto max-w-6xl px-5">
      <div class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">Why Videotrim</span>
        <h2 class="text-balance mt-3 font-display text-4xl md:text-5xl">Everything the edit used to take all day</h2>
      </div>

      <div class="mt-14 grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => (
          <div class="flex gap-4">
            <span class="shrink-0 text-primary">
              <svg viewBox="-5 -10 110 135" fill="currentColor" class="h-16 w-16">
                <path d={icons[f.icon]} />
              </svg>
            </span>
            <div>
              <h3 class="text-lg">{f.title}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">{f.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="mx-auto max-w-6xl px-5 py-40 md:py-52">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">How it works</span>
      <h2 class="text-balance mt-3 font-display text-4xl md:text-5xl">From upload to upload in four steps</h2>
      <p class="mt-4 text-muted-foreground">No timeline to learn. No clips to hunt for. Just results.</p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 md:grid-cols-4">
      {steps.map((step) => (
        <div class="group relative">
          <span class="font-display text-5xl text-primary/25 transition-colors duration-700 ease-out group-hover:text-primary group-hover:duration-200">{step.n}</span>
          <h3 class="mt-3 text-xl">{step.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{step.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA hero -->
  <section class="relative overflow-hidden bg-card px-6 py-32 text-center md:py-44">
      <div class="pointer-events-none absolute -bottom-24 left-1/2 h-72 w-[36rem] -translate-x-1/2 rounded-full bg-primary/10 blur-3xl"></div>
      <div class="relative">
        <h2 class="text-balance mx-auto max-w-2xl font-display text-4xl md:text-5xl">
          Your next video is hiding clips. Let's find them.
        </h2>
        <p class="mx-auto mt-4 max-w-md text-muted-foreground">
          Start with three free videos. No credit card, no editing skills, no excuses.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href="/signup" class="btn btn-primary btn-lg">Create free account</a>
          <a href="/support" class="btn btn-outline btn-lg">Talk to us</a>
        </div>
      </div>
  </section>
</Layout>
