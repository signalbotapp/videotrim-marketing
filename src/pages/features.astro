---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    icon: 'sparkles',
    title: 'Moment detection',
    body: 'Videotrim transcribes your video, then scores every segment on hook strength, story arc, and quotability. You get a ranked list of the best moments instead of a blank timeline to scrub.',
  },
  {
    icon: 'captions',
    title: 'Word-perfect captions',
    body: 'Accurate, word-by-word captions added to every clip automatically — the rhythm that holds attention on a silent feed. Fix a word and the timing follows; nothing to re-sync by hand.',
  },
  {
    icon: 'crop',
    title: 'Vertical or wide reframing',
    body: 'Export tall for Shorts, Reels, and TikTok, or keep it wide for YouTube and LinkedIn — nudge the framing so your subject sits where you want it.',
  },
  {
    icon: 'layers',
    title: 'One source, many clips',
    body: 'Turn a single recording into a batch of ready-to-post clips in one pass. Record once, harvest a week of content, export the keepers together.',
  },
  {
    icon: 'palette',
    title: 'Caption styles that are yours',
    body: 'Choose from multiple caption presets to match your look. Save your font, color, and placement once and every clip carries the same signature.',
  },
  {
    icon: 'zap',
    title: 'Clean cuts, fast',
    body: 'Cuts land on the audio — never mid-word, never on silence. A long video becomes polished clips while you grab coffee. No timeline, no scrubbing.',
  },
];

const workflow = [
  { n: '01', title: 'Upload', body: 'Drop in a podcast, webinar, interview, vlog, or stream — or paste a YouTube or Vimeo link.' },
  { n: '02', title: 'AI finds the moments', body: 'Videotrim transcribes, scores, and cuts on the audio to surface a ranked list of clip candidates.' },
  { n: '03', title: 'Refine', body: 'Adjust the in/out points, fix caption wording, or reanalyze with a new prompt until each clip is right.' },
  { n: '04', title: 'Export', body: 'Vertical or wide, word-perfect captions, full HD, no watermark — ready for every platform.' },
];

