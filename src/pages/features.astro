---

<Layout
  title="Features — everything Videotrim does"
  description="Moment detection, word-perfect auto captions, vertical reframing, and clean cuts — the full feature set that turns a long recording into ready-to-post clips."
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute -top-32 left-1/2 h-80 w-[42rem] -translate-x-1/2 rounded-full bg-primary/10 blur-3xl"></div>
    <div class="mx-auto max-w-3xl px-5 pt-16 pb-10 text-center md:pt-24">
      <span class="eyebrow">Features</span>
      <h1 class="text-balance mt-3 font-display text-5xl leading-[1.05] md:text-6xl">
        Everything the edit used to take all day
      </h1>
      <p class="text-balance mx-auto mt-5 max-w-xl text-lg text-muted-foreground">
        Videotrim finds the moments, cuts them clean, and captions them for a
        silent feed — so the only job left is deciding what to post.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="https://app.videotrim.ai/signup" class="btn btn-primary btn-lg">Start free — no card needed</a>
        <a href="/pricing" class="btn btn-outline btn-lg">See pricing</a>
      </div>
    </div>
  </section>

  <!-- Feature grid -->
  <section class="mx-auto max-w-6xl px-5 py-24 md:py-28">
    <div class="grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <div class="flex gap-4">
          <span class="shrink-0 text-primary">
            <svg viewBox="-5 -10 110 135" fill="currentColor" class="h-14 w-14">
              <path d={icons[f.icon]} />
            </svg>
          </span>
          <div>
            <h2 class="text-lg">{f.title}</h2>
            <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">{f.body}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Caption spotlight -->
  <section class="dark relative isolate overflow-hidden bg-background text-foreground py-28 md:py-32">
    <img src="/ai-editor-mockup.jpg" alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" />
    <div class="absolute inset-0 -z-10 bg-black/80"></div>
    <div class="mx-auto grid max-w-5xl items-center gap-10 px-5 lg:grid-cols-2">
      <div>
        <span class="eyebrow">Built for the mute scroll</span>
        <h2 class="text-balance mt-3 font-display text-3xl md:text-4xl">Captions are the new thumbnail</h2>
        <p class="mt-4 leading-relaxed text-muted-foreground">
          Most short-form is watched without sound, so the first line of caption
          text is your hook. Videotrim writes word-by-word captions that land in
          sync with the speaker — the rhythm that keeps a thumb from scrolling on.
        </p>
        <a href="/blog/how-muted-viewing-optimization-works/" class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-primary">
          How muted-viewing optimization works
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
      <ul class="space-y-4">
        {[
          'Word-level timing, synced to the speaker',
          'Edit a word — the timing follows automatically',
          'Presets for font, color, and placement',
          'Full HD exports, no watermark',
        ].map((item) => (
          <li class="flex items-start gap-3 rounded-[var(--radius-card)] border border-card-border-subtle bg-card/40 p-4 text-sm">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 shrink-0 text-primary"><path d="M20 6L9 17l-5-5"/></svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Workflow -->
  <section class="mx-auto max-w-6xl px-5 py-24 md:py-28">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">How it works</span>
      <h2 class="text-balance mt-3 font-display text-4xl md:text-5xl">From video to clips in four steps</h2>
      <p class="mt-4 text-muted-foreground">No timeline to learn. No clips to hunt for. Just results.</p>
    </div>
    <div class="mt-14 grid gap-6 sm:grid-cols-2 md:grid-cols-4">
      {workflow.map((step) => (
        <div class="group relative">
          <span class="font-display text-5xl text-primary/25 transition-colors duration-700 ease-out group-hover:text-primary group-hover:duration-200">{step.n}</span>
          <h3 class="mt-3 text-xl">{step.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{step.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden bg-card px-6 py-28 text-center md:py-36">
    <div class="pointer-events-none absolute -bottom-24 left-1/2 h-72 w-[36rem] -translate-x-1/2 rounded-full bg-primary/10 blur-3xl"></div>
    <div class="relative">
      <h2 class="text-balance mx-auto max-w-2xl font-display text-4xl md:text-5xl">
        See it on your own footage
      </h2>
      <p class="mx-auto mt-4 max-w-md text-muted-foreground">
        Sign up free — 2 tokens on us. No subscription, no editing skills required.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="https://app.videotrim.ai/signup" class="btn btn-primary btn-lg">Create free account</a>
        <a href="/use-cases" class="btn btn-outline btn-lg">Explore use cases</a>
      </div>
    </div>
  </section>
</Layout>
