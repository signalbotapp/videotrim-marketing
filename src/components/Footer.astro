---
import Logo from './Logo.astro';

const year = new Date().getFullYear();
---

<footer class="relative z-10 border-t border-border/70">
  <div class="mx-auto max-w-6xl px-5 py-14">
    <div class="max-w-xs">
      <Logo class="h-5 w-auto text-primary" />
      <p class="mt-4 text-sm leading-relaxed text-muted-foreground">
        Turn long videos into ready-to-post clips. Videotrim finds the best
        moments and captions them automatically.
      </p>
    </div>
  </div>

  <div class="border-t border-border/70">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-3 px-5 py-6 text-xs text-muted-foreground sm:flex-row">
      <p>© {year} Videotrim. All rights reserved.</p>
      <p>Made for creators who'd rather create.</p>
    </div>
  </div>
</footer>
