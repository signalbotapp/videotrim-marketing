---
import Logo from './Logo.astro';

const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const nav = [
  { href: '/', label: 'Home' },
  { href: '/features', label: 'Features' },
  { href: '/use-cases', label: 'Use cases' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/blog', label: 'Blog' },
  { href: '/support', label: 'Support' },
];

const linkClass = (href: string) =>
  [
    'rounded-md px-3 py-2 text-sm font-medium transition-colors',
    isActive(href) ? 'text-foreground' : 'text-muted-foreground hover:text-foreground',
  ].join(' ');
---

<header id="site-header" class="sticky top-0 z-40 transition-all duration-300 ease-out">
  <div class="mx-auto max-w-6xl px-4 sm:px-5">
    <div class="flex h-16 items-center justify-between gap-4">
      <a href="/" class="flex shrink-0 items-center gap-2 text-foreground hover-elevate" aria-label="Videotrim home">
        <Logo class="h-10 w-auto text-primary" />
      </a>

      <!-- Inline nav (tablet / desktop) -->
      <nav class="hidden items-center gap-1 sm:flex">
        {nav.map((item) => (
          <a href={item.href} class={linkClass(item.href)}>{item.label}</a>
        ))}
      </nav>

      <div class="flex shrink-0 items-center gap-2">
        <a href="/login" class="btn btn-ghost hidden sm:inline-flex">Log in</a>
        <a href="/signup" class="btn btn-primary">Start free</a>
      </div>
    </div>

    <!-- Second-row nav (mobile only) -->
    <nav class="no-scrollbar flex items-center justify-start gap-0.5 overflow-x-auto pb-2 sm:hidden">
      {nav.map((item) => (
        <a href={item.href} class={`${linkClass(item.href)} shrink-0`}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  if (header) {
    // Background/border/blur applied only once the page is scrolled away from the top.
    const bgClasses = ['border-b', 'border-border/70', 'bg-background/80', 'backdrop-blur-md'];
    let lastY = window.scrollY;
    let ticking = false;

    const update = () => {
      const y = window.scrollY;
      const goingDown = y > lastY;

      // Fade the background in once scrolled; keep it transparent at the very top.
      if (y > 4) {
        header.classList.add(...bgClasses);
      } else {
        header.classList.remove(...bgClasses);
      }

      // Hide when scrolling down past the header's height; show when scrolling up or near the top.
      if (goingDown && y > header.offsetHeight) {
        header.style.transform = 'translateY(-100%)';
      } else {
        header.style.transform = 'translateY(0)';
      }
      lastY = y;
      ticking = false;
    };

    update();

    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          window.requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true }
    );
  }
</script>
